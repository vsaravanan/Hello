
# Short aliases
alias k='kubectl'
alias kgp='kubectl get pods'
alias kgpo='kubectl get pods -o custom-columns=NAME:.metadata.name,IP:.status.podIP,NODE:.spec.nodeName'
alias kgd='kubectl get deployments'
alias kgs='kubectl get services'
alias kgso='kubectl get svc -o custom-columns=NAME:.metadata.name,CLUSTER-IP:.spec.clusterIP,PORT:.spec.ports[*].port'
alias kgn='kubectl get nodes'
alias kga='kubectl get all -A'
alias kgag='kubectl get all -A | grep '
alias ksd='kubectl scale deployment'
alias kge='kubectl get endpoints'

# With more options
alias kgpa='kubectl get pods --all-namespaces'
alias kgpw='kubectl get pods -w'  # watch mode
alias kgpwide='kubectl get pods -o wide'

# Describe shortcuts
alias kbp='kubectl describe pod'
alias kbd='kubectl describe deployment'
alias kbs='kubectl describe svc'

# Delete shortcuts
alias kdp='kubectl delete pod'
alias kdapp='kubectl delete pod -l'
alias kdpf='kubectl delete pods --field-selector=status.phase=Failed'
alias kdd='kubectl delete deployment'
alias kds='kubectl delete svc'


#alias kdall='kubectl delete --all'

# Logs shortcut
alias kl='kubectl logs'
alias klf='kubectl logs -f'  # follow logs





